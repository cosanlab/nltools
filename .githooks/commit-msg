#!/usr/bin/env bash
# Enforce conventional commits using a simple regex.
# Allowed types: feat, fix, docs, style, refactor, perf, test, chore, ci, build, revert

msg=$(head -1 "$1")

# Allow merge commits
if echo "$msg" | grep -qE '^Merge '; then
  exit 0
fi

pattern='^(feat|fix|docs|style|refactor|perf|test|chore|ci|build|revert)(\(.+\))?!?: .+'

if ! echo "$msg" | grep -qE "$pattern"; then
  echo "ERROR: Commit message does not follow Conventional Commits format."
  echo ""
  echo "  Expected: <type>[optional scope]: <description>"
  echo "  Examples: feat: add changelog generation"
  echo "            fix(stats): correct p-value formula"
  echo "            docs(api): update BrainData reference"
  echo ""
  echo "  Allowed types: feat, fix, docs, style, refactor, perf, test, chore, ci, build, revert"
  echo ""
  echo "  Got: $msg"
  exit 1
fi
